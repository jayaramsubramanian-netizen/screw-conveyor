import React, { useState, useEffect } from 'react'
import CalculatorPage   from './pages/CalculatorPage'
import FamilyDesignerPage from './pages/FamilyDesignerPage'
import ProcessPage      from './pages/ProcessPage'
import DatabasePage     from './pages/DatabasePage'

const NAV = [
  {
    group: 'Design',
    items: [
      { id: 'calculator', icon: '📐', label: 'Conveyor Calculator', sub: 'CEMA · KWS · DIN' },
      { id: 'family',     icon: '📋', label: 'Family Designer',     sub: 'Diameter × Length matrix' },
    ]
  },
  {
    group: 'Process Modules',
    items: [
      { id: 'process',    icon: '⚗️', label: 'Process Calculator',  sub: 'Mix · Dry · Cool · Separate' },
    ]
  },
  {
    group: 'Data',
    items: [
      { id: 'database',   icon: '🗄️', label: 'Database Manager',    sub: 'Materials · Bearings · Costs' },
    ]
  },
]

export default function App() {
  const [page, setPage] = useState('calculator')
  const [sidebarOpen, setSidebarOpen] = useState(true)
  const [backendOk, setBackendOk] = useState(null)

  useEffect(() => {
    fetch('/api/health')
      .then(r => r.json())
      .then(d => setBackendOk(d.status === 'ok'))
      .catch(() => setBackendOk(false))
  }, [])

  const currentItem = NAV.flatMap(g => g.items).find(i => i.id === page)

  return (
    <div className="flex h-screen bg-gray-50 overflow-hidden">
      {/* ── Sidebar ──────────────────────────────────────────────────── */}
      <aside className={`flex flex-col bg-[#1e3a5f] text-white transition-all duration-200 ${sidebarOpen ? 'w-64' : 'w-16'} shrink-0`}>
        {/* Logo */}
        <div className="flex items-center gap-3 px-4 py-5 border-b border-white/10">
          <span className="text-2xl shrink-0">🔩</span>
          {sidebarOpen && (
            <div>
              <p className="font-bold text-sm leading-tight">Screw Conveyor</p>
              <p className="text-xs text-blue-200 leading-tight">Designer v2.0</p>
            </div>
          )}
          <button onClick={() => setSidebarOpen(p => !p)}
            className="ml-auto text-blue-300 hover:text-white text-lg leading-none shrink-0">
            {sidebarOpen ? '◀' : '▶'}
          </button>
        </div>

        {/* Nav groups */}
        <nav className="flex-1 overflow-y-auto py-3 space-y-4">
          {NAV.map(group => (
            <div key={group.group}>
              {sidebarOpen && (
                <p className="text-xs font-bold uppercase tracking-widest text-blue-300/60 px-4 mb-1">
                  {group.group}
                </p>
              )}
              {group.items.map(item => (
                <button
                  key={item.id}
                  onClick={() => setPage(item.id)}
                  className={`w-full flex items-center gap-3 px-4 py-2.5 transition-colors text-left
                    ${page === item.id
                      ? 'bg-white/15 text-white border-r-2 border-white'
                      : 'text-blue-100 hover:bg-white/10 hover:text-white'
                    }`}
                >
                  <span className="text-xl shrink-0">{item.icon}</span>
                  {sidebarOpen && (
                    <div className="min-w-0">
                      <p className="text-sm font-medium leading-tight truncate">{item.label}</p>
                      <p className="text-xs text-blue-300 leading-tight truncate">{item.sub}</p>
                    </div>
                  )}
                </button>
              ))}
            </div>
          ))}
        </nav>

        {/* Backend status */}
        <div className={`px-4 py-3 border-t border-white/10 flex items-center gap-2 ${sidebarOpen ? '' : 'justify-center'}`}>
          <span className={`w-2 h-2 rounded-full shrink-0 ${backendOk === null ? 'bg-yellow-400' : backendOk ? 'bg-green-400' : 'bg-red-400'}`} />
          {sidebarOpen && (
            <span className="text-xs text-blue-200">
              {backendOk === null ? 'Connecting…' : backendOk ? 'API Connected' : 'API Offline'}
            </span>
          )}
        </div>
      </aside>

      {/* ── Main content ─────────────────────────────────────────────── */}
      <div className="flex-1 flex flex-col overflow-hidden">
        {/* Top bar */}
        <header className="bg-white border-b border-gray-100 px-6 py-3 flex items-center gap-4 shrink-0">
          <div>
            <h1 className="font-bold text-gray-800 text-base leading-tight">
              {currentItem?.icon} {currentItem?.label}
            </h1>
            <p className="text-xs text-gray-400">{currentItem?.sub}</p>
          </div>
          {backendOk === false && (
            <div className="ml-auto text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-1.5">
              ⚠ Backend API not reachable — start <code className="font-mono text-xs">uvicorn main:app</code> in the backend folder
            </div>
          )}
        </header>

        {/* Page content */}
        <main className="flex-1 overflow-y-auto p-6">
          {page === 'calculator' && <CalculatorPage />}
          {page === 'family'     && <FamilyDesignerPage />}
          {page === 'process'    && <ProcessPage />}
          {page === 'database'   && <DatabasePage />}
        </main>
      </div>
    </div>
  )
}
